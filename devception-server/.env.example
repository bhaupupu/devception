PORT=4000
NODE_ENV=development

MONGODB_URI=mongodb://localhost:27017/Devception

# Must match NEXTAUTH_SECRET in devception-client.
NEXTAUTH_SECRET=replace-with-a-long-random-secret

# Local: http://localhost:3000
# Production: https://devception.vercel.app
CLIENT_ORIGIN=http://localhost:3000
CLIENT_ORIGINS=http://localhost:3000,https://devception.vercel.app
ALLOW_VERCEL_PREVIEWS=false

IMPOSTER_BUG_COOLDOWN_MS=45000
IMPOSTER_BLUR_COOLDOWN_MS=60000
IMPOSTER_HINT_COOLDOWN_MS=30000

GAME_DURATION_MS=900000
MEETING_DISCUSSION_MS=60000
MEETING_VOTING_MS=30000
MAX_PLAYERS=8
MIN_PLAYERS=4
