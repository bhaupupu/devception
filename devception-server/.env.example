# ─────────────────────────────────────────────────────────────────────────────
# devception-server — Environment Variables Template
# Copy this file and fill in real values. Never commit the file with secrets.
#
# Platform notes:
#   Railway  → set via dashboard or railway.json (Railway auto-injects PORT)
#   Render   → set via dashboard (Render auto-injects PORT and RENDER=true)
#   Local    → copy to .env and fill in values
# ─────────────────────────────────────────────────────────────────────────────

# ── Runtime ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
# LOCAL DEVELOPMENT:
#   MONGODB_URI=mongodb://localhost:27017/codecrew
#
# PRODUCTION (MongoDB Atlas — required for Render AND Railway if not using plugin):
#   1. Create a free M0 cluster at https://cloud.mongodb.com
#   2. Create a database user with readWrite on the 'codecrew' database
#   3. Under Network Access → Add IP Address → Allow from anywhere (0.0.0.0/0)
#   4. Click "Connect" → "Connect your application" → copy the SRV string below
#
#   MONGODB_URI=mongodb+srv://<db-user>:<db-password>@cluster0.mcfujw9.mongodb.net/codecrew?retryWrites=true&w=majority
#
# ⚠️  Railway-internal URIs (e.g. mongodb://mongo.railway.internal/...) ONLY work
#     inside Railway's private network — they will NOT work on Render.
MONGODB_URI=mongodb+srv://<db-user>:<db-password>@cluster0.mcfujw9.mongodb.net/codecrew?retryWrites=true&w=majority

# ── Auth ──────────────────────────────────────────────────────────────────────
# Must match NEXTAUTH_SECRET in devception-client/.env.local (and Vercel dashboard)
# Generate a secure value:  openssl rand -hex 32
NEXTAUTH_SECRET=change-me-use-openssl-rand-hex-32

# ── CORS ──────────────────────────────────────────────────────────────────────
# The origin of the frontend. In production set to your Vercel deployment URL.
# Example: https://devception.vercel.app
# Vercel preview deployments (*.vercel.app) are allowed automatically in code.
CLIENT_ORIGIN=http://localhost:3000

# ── Game settings ─────────────────────────────────────────────────────────────
GAME_DURATION_MS=900000
MEETING_DISCUSSION_MS=60000
MEETING_VOTING_MS=30000
MAX_PLAYERS=8
MIN_PLAYERS=4

# ── Imposter cooldowns ────────────────────────────────────────────────────────
IMPOSTER_BUG_COOLDOWN_MS=45000
IMPOSTER_BLUR_COOLDOWN_MS=60000
IMPOSTER_HINT_COOLDOWN_MS=30000
